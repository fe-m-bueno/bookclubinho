# =============================================================================
#  Bookclub — Backend Environment Variables
#  Copy to /backend/.env and fill in real values.
#  NEVER commit the real .env file.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
# Runtime environment: dev | staging | prod
ENVIRONMENT=dev

# Public URL of the Vercel frontend (used in email links and as CORS origin)
APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (no trailing slashes)
# In prod, set to your Vercel domain: https://bookclubinho.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Database — Railway PostgreSQL ────────────────────────────────────────────
# Railway provides $DATABASE_URL automatically in the service env.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Note: the +asyncpg driver suffix is required for SQLAlchemy async support.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bookclub

# ── Redis — Upstash ───────────────────────────────────────────────────────────
# TCP URL — used for SSE (XREAD/BLOCK) and pub/sub in the notification worker.
# Must be a rediss:// (TLS) URL in production.
REDIS_URL=redis://localhost:6379

# Upstash REST API — used for lightweight cache operations (no persistent conn).
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Storage — Cloudflare R2 (S3-compatible) ───────────────────────────────────
# Account-level endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 API token credentials (generate in Cloudflare dashboard → R2 → Manage API tokens)
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key

# Bucket name for public assets (avatars, group covers)
S3_BUCKET_NAME=bookclub-public

# Custom domain attached to the public bucket (R2 → Settings → Custom Domains)
S3_PUBLIC_URL=https://pub.yourdomain.com

# ── JWT / Authentication ──────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# Signing algorithm (do not change unless you know what you're doing)
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must match APP_URL/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email — Resend ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Verified sender domain (must be a domain verified in Resend dashboard)
RESEND_FROM_EMAIL=noreply@bookclub.app

# ── External APIs — Hardcover ─────────────────────────────────────────────────
# GraphQL API for book search/metadata — https://hardcover.app/account/api
HARDCOVER_API_URL=https://api.hardcover.app/v1/graphql
HARDCOVER_API_TOKEN=your-hardcover-api-token

# ── Observability — Sentry ────────────────────────────────────────────────────
# Leave empty to disable Sentry in dev
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
